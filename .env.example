# ===========================================================================
# BitNet — Environment Configuration Template
# ===========================================================================
# Copy this file to .env and fill in the values.
#   cp .env.example .env
#
# NEVER commit .env to version control.
# ===========================================================================

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
# SQLite (default for single-instance deployment)
SQLALCHEMY_DATABASE_URL=sqlite:////app/data/bitnet.db

# For PostgreSQL (uncomment and configure if using external DB):
# SQLALCHEMY_DATABASE_URL=postgresql+asyncpg://bitnet:password@db:5432/bitnet

# ---------------------------------------------------------------------------
# Server Wrap Key (FIDO2 double-wrap strategy)
# ---------------------------------------------------------------------------
# Path to the 32-byte server wrap key file (inside container).
# The file must exist and contain exactly 32 random bytes.
BITNET_SERVER_WRAP_KEY_FILE=/run/secrets/server_key

# For local development (outside Docker), set to a file path:
# BITNET_SERVER_WRAP_KEY_FILE=./secrets/server_key.txt

# ---------------------------------------------------------------------------
# FIDO2 / WebAuthn
# ---------------------------------------------------------------------------
# Relying Party ID (must match your domain)
# BITNET_FIDO2_RP_ID=localhost
# BITNET_FIDO2_ORIGIN=http://localhost:8000

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Number of uvicorn workers (auto-tuned to CPU cores if not set)
# UVICORN_WORKERS=4

# Bind address and port
UVICORN_HOST=0.0.0.0
UVICORN_PORT=8000

# ---------------------------------------------------------------------------
# Security
# ---------------------------------------------------------------------------
# Argon2id memory cost in KB (default: 65536 = 64 MB)
# ARGON2_MEMORY_COST=65536

# Argon2id time cost (iterations)
# ARGON2_TIME_COST=3

# Argon2id parallelism
# ARGON2_PARALLELISM=4

# Auto-lock timeout in seconds (session idle)
# AUTO_LOCK_TIMEOUT=300

# Max failed login attempts before rate limit
# MAX_LOGIN_ATTEMPTS=5

# ---------------------------------------------------------------------------
# Rate Limiting
# ---------------------------------------------------------------------------
# Rate limit window (seconds)
# RATE_LIMIT_WINDOW=60

# Block duration after max attempts (seconds)
# BLOCK_DURATION=1800

# ---------------------------------------------------------------------------
# CORS (if serving frontend from different origin)
# ---------------------------------------------------------------------------
# Comma-separated list of allowed origins
# CORS_ORIGINS=http://localhost:5173,https://yourdomain.com

# ---------------------------------------------------------------------------
# Docker / Production Overrides
# ---------------------------------------------------------------------------
# Set these in docker-compose.yml or your orchestration platform.
# Do NOT set them here for production deployments.
